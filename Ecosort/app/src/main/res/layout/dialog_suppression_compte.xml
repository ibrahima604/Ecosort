<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header rouge danger -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#B71C1C">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="32sp" />
            </LinearLayout>

            <!-- Corps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Supprimer mon compte"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="#B71C1C"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cette action est définitive et irréversible. Toutes vos données, statistiques et historique seront supprimés définitivement."
                    android:textSize="13sp"
                    android:textColor="#616161"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="24dp" />

                <!-- Bouton Supprimer -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmerSuppression"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Oui, supprimer définitivement"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#C62828"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="10dp" />

                <!-- Bouton Annuler -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnnulerSuppression"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Annuler"
                    android:textAllCaps="false"
                    android:textColor="#424242"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#BDBDBD"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
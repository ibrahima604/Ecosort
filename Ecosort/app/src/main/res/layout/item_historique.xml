<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icone rond -->
        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_icon_green_round"
            android:layout_marginEnd="14dp">

            <TextView
                android:id="@+id/tvIconeHistorique"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:text="♻" />
        </FrameLayout>

        <!-- Infos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEtiquetteHistorique"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:text="Type de déchet" />

            <TextView
                android:id="@+id/tvDateHistorique"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#90A4AE"
                android:layout_marginTop="3dp"
                android:text="25/12/2024 a 14:30" />
        </LinearLayout>

        <!-- Badge plastique / non plastique -->
        <TextView
            android:id="@+id/tvIndicateurHistorique"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plastique"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_green"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
<resources>
    <style name="CoolTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="hintTextColor">#2E7D32</item>
        <item name="boxStrokeColor">@color/text_input_stroke_color</item>
        <item name="boxBackgroundColor">#FFFFFF</item>
        <item name="hintTextAppearance">@style/CoolHintTextAppearance</item>
        <item name="boxCollapsedPaddingTop">8dp</item>
        <item name="android:textCursorDrawable">@drawable/custom_cursor</item>
    </style>

    <style name="CoolHintTextAppearance" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">#2E7D32</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>